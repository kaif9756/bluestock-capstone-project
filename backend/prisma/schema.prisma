generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")

}

model DailyScore {
  id             String   @id @default(uuid())
  userId         String?
  guestId        String?
  date           String
  score          Int
  completionTime Int
  createdAt      DateTime @default(now())

  @@unique([userId, date])
  @@unique([guestId, date])
}